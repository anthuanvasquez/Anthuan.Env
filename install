#!/usr/bin/env bash
# install: Orchestrator for setting up the environment.

set -e

# Setup base path
DOTFILES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DOTFILES_ROOT"

echo "🎯 Environment Orchestrator"

# 1. Create Symlinks
./scripts/link-dotfiles

# 2. Package Installation
echo "🍺 Setting up Homebrew..."
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

echo "📦 Installing packages from Brewfile..."
./scripts/install-packages

# 3. Apply settings
echo "⚙️ Applying macOS settings..."
./os/macos.sh

# 4. Modules Setup (auto-discovery)
echo "🧩 Configuring Modules..."

for module_script in modules/*/install.sh; do
    module_name="$(basename "$(dirname "$module_script")")"
    module_name_upper="$(echo "$module_name" | tr '[:lower:]' '[:upper:]')"
    echo "   [$module_name_upper] Running installer..."
    bash "$module_script"
done

echo "✨ All done! Open a new shell to enjoy your setup."
