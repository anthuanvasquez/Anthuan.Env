#!/usr/bin/env bash
# docker-reset: Clean up docker containers, images, and volumes.

set -e

echo "⚠️  WARNING: This will stop and remove ALL containers, images, and volumes."
read -p "Are you sure you want to proceed? (y/N) " confirm

if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "❌ Reset cancelled."
    exit 0
fi

echo "🧹 Cleaning up Docker..."

# Stop all containers
if [ "$(docker ps -aq)" ]; then
    echo "   [CONTAINERS] Stopping and removing..."
    docker stop $(docker ps -aq)
    docker rm $(docker ps -aq)
fi

# Remove dangling images
if [ "$(docker images -q -f dangling=true)" ]; then
    echo "   [IMAGES] Pruning dangling images..."
    docker rmi $(docker images -q -f dangling=true)
fi

# Remove unused volumes
echo "   [VOLUMES] Pruning unused volumes..."
docker volume prune -f

# System prune
echo "   [SYSTEM] Deep cleaning..."
docker system prune -a --volumes -f

echo "✅ Docker is clean as a whistle."
