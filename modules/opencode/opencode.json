{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "mcp": {
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server", "OPENAPI_MCP_HEADERS", "{\"Authorization\": \"Bearer TOKEN\", \"Notion-Version\": \"2022-06-28\"}"]
    },
    "notebooklm": {
      "type": "local",
      "command": ["npx", "notebooklm-mcp@latest"]
    },
    "engram": {
      "type": "local",
      "command": ["engram", "mcp"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "TOKEN"
      },
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"]
    }
  }
}