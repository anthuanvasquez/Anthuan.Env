# Dockerfile.test
# Comprehensive sandbox for testing the FAANG-style Dotfiles.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Essential dependencies for a dev machine
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    sudo \
    procps \
    file \
    uuid-runtime \
    zsh \
    && rm -rf /var/lib/apt/lists/*

# Non-root developer user
RUN useradd -m -s /bin/zsh developer && \
    echo "developer ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER developer
WORKDIR /home/developer

# Pre-install Homebrew
RUN /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
ENV PATH="/home/developer/.linuxbrew/bin:/home/developer/.linuxbrew/sbin:${PATH}"

# Prepare repository
WORKDIR /home/developer/dotfiles
COPY --chown=developer:developer . .

# Sandbox Test Suite
RUN echo '#!/bin/bash \n\
set -e \n\
echo "🚀 FAANG DOTFILES SANDBOX TEST" \n\
\n\
echo "--- Step 1: Running Orchestrator ---" \n\
# Bypassing gh CLI if not logged in \n\
./install \n\
\n\
echo "--- Step 2: Running Environment Diagnostics ---" \n\
./bin/doctor \n\
\n\
echo "--- Step 3: Verifying Symlinks ---" \n\
files=(".zshrc" ".gitconfig" ".gitignore_global") \n\
for f in "${files[@]}"; do \n\
    [ -L "$HOME/$f" ] && echo "✅ $f symlink OK" || echo "❌ $f symlink MISSING" \n\
done \n\
\n\
echo "--- Step 4: Testing Workflow Commands ---" \n\
./bin/dev --help && echo "✅ dev command available" \n\
./bin/dot --help && echo "✅ dot command available" \n\
\n\
echo "✨ ALL TESTS PASSED!" \n\
' > test-suite.sh && chmod +x test-suite.sh

CMD ["./test-suite.sh"]
